{
  "manifest_version": 3,
  "name": "tapto — Reprogrammable NFC & QR Tags",
  "version": "0.1.0",
  "description": "Create NFC and QR tags you can repoint anytime — change where a tag goes without ever rewriting it. Your data in your own GitHub.",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": [
    "https://github.com/login/device/*",
    "https://github.com/login/oauth/*",
    "https://api.github.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "tapto" },
  "side_panel": { "default_path": "sidepanel.html" },
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
}
